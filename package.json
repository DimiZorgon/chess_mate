{
  "name": "chess-mate",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "client": "npm run dev --workspace client",
    "server": "npm run dev --workspace server",
    "dev": "concurrently \"npm run client\" \"npm run server\"",
    "start": "npm run start --workspace server"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
